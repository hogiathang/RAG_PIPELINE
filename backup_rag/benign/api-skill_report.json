{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "Remote Code Execution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies patterns that could allow an attacker to execute arbitrary code on the system, potentially leading to full system compromise."
                            },
                            "helpUri": "https://example.com/help/RCE-001"
                        },
                        {
                            "id": "DATA-EXFIL-002",
                            "name": "Data Exfiltration",
                            "shortDescription": {
                                "text": "Detects attempts to exfiltrate sensitive data."
                            },
                            "fullDescription": {
                                "text": "Flags code that attempts to send sensitive information to external, unauthorized destinations."
                            },
                            "helpUri": "https://example.com/help/DATA-EXFIL-002"
                        },
                        {
                            "id": "PRIV-ESC-003",
                            "name": "Privilege Escalation",
                            "shortDescription": {
                                "text": "Detects potential privilege escalation vectors."
                            },
                            "fullDescription": {
                                "text": "Identifies code constructs that could allow a user or process to gain higher privileges than intended."
                            },
                            "helpUri": "https://example.com/help/PRIV-ESC-003"
                        },
                        {
                            "id": "SEC-WARN-004",
                            "name": "Security Misconfiguration",
                            "shortDescription": {
                                "text": "Detects common security misconfigurations."
                            },
                            "fullDescription": {
                                "text": "Flags configurations or code patterns that deviate from security best practices, potentially exposing the system to risks."
                            },
                            "helpUri": "https://example.com/help/SEC-WARN-004"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}