{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "ArbitraryCodeExecution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies patterns or constructs that could allow an attacker to execute arbitrary commands or code on the system, leading to full system compromise."
                            },
                            "helpUri": "https://example.com/help/RCE-001"
                        },
                        {
                            "id": "DATA-EXFIL-001",
                            "name": "DataExfiltration",
                            "shortDescription": {
                                "text": "Detects potential data exfiltration attempts."
                            },
                            "fullDescription": {
                                "text": "Flags code that might attempt to send sensitive data to unauthorized external destinations, indicating a data exfiltration risk."
                            },
                            "helpUri": "https://example.com/help/DATA-EXFIL-001"
                        },
                        {
                            "id": "SEC-WARN-001",
                            "name": "GeneralSecurityWarning",
                            "shortDescription": {
                                "text": "Identifies general security weaknesses or misconfigurations."
                            },
                            "fullDescription": {
                                "text": "Highlights code patterns or configurations that, while not direct exploits, could lead to security vulnerabilities if not properly addressed."
                            },
                            "helpUri": "https://example.com/help/SEC-WARN-001"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}