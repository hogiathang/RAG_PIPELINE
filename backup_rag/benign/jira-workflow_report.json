{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "Remote Code Execution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies code patterns that could allow an attacker to execute arbitrary commands on the host system, leading to full system compromise."
                            },
                            "helpUri": "https://example.com/rce-001"
                        },
                        {
                            "id": "DATA-EXFIL-002",
                            "name": "Data Exfiltration",
                            "shortDescription": {
                                "text": "Detects unauthorized data exfiltration attempts."
                            },
                            "fullDescription": {
                                "text": "Flags code that attempts to send sensitive data to unauthorized external destinations, potentially leading to data breaches."
                            },
                            "helpUri": "https://example.com/data-exfil-002"
                        },
                        {
                            "id": "AUTH-BYPASS-003",
                            "name": "Authentication Bypass",
                            "shortDescription": {
                                "text": "Detects authentication bypass vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies flaws that could allow an attacker to circumvent authentication mechanisms and gain unauthorized access."
                            },
                            "helpUri": "https://example.com/auth-bypass-003"
                        },
                        {
                            "id": "PRIV-ESC-004",
                            "name": "Privilege Escalation",
                            "shortDescription": {
                                "text": "Detects privilege escalation vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Flags code that could allow a low-privileged user to gain higher-level access or control within the system."
                            },
                            "helpUri": "https://example.com/priv-esc-004"
                        },
                        {
                            "id": "SEC-WARN-005",
                            "name": "Security Misconfiguration",
                            "shortDescription": {
                                "text": "Detects common security misconfigurations."
                            },
                            "fullDescription": {
                                "text": "Identifies insecure configurations or practices that could expose the system to various risks."
                            },
                            "helpUri": "https://example.com/sec-warn-005"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}