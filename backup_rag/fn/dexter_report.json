{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "RemoteCodeExecution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies patterns or configurations that could allow an attacker to execute arbitrary code on the system where the agent is running."
                            },
                            "helpUri": "https://example.com/help/RCE-001"
                        },
                        {
                            "id": "DATA-EXFIL-001",
                            "name": "DataExfiltration",
                            "shortDescription": {
                                "text": "Detects potential data exfiltration attempts."
                            },
                            "fullDescription": {
                                "text": "Flags code that attempts to send sensitive data to unauthorized external destinations or uses suspicious communication channels."
                            },
                            "helpUri": "https://example.com/help/DATA-EXFIL-001"
                        },
                        {
                            "id": "CRED-THEFT-001",
                            "name": "CredentialTheft",
                            "shortDescription": {
                                "text": "Identifies code designed to steal credentials."
                            },
                            "fullDescription": {
                                "text": "Looks for patterns indicative of credential harvesting, such as accessing sensitive files, environment variables, or interacting with authentication mechanisms in an unusual way."
                            },
                            "helpUri": "https://example.com/help/CRED-THEFT-001"
                        },
                        {
                            "id": "MAL-BEHAV-001",
                            "name": "MaliciousBehavior",
                            "shortDescription": {
                                "text": "Detects general malicious or suspicious behavior."
                            },
                            "fullDescription": {
                                "text": "Flags activities that, while not fitting specific categories, are highly indicative of malicious intent or could lead to system compromise."
                            },
                            "helpUri": "https://example.com/help/MAL-BEHAV-001"
                        },
                        {
                            "id": "SEC-WARN-001",
                            "name": "SecurityWarning",
                            "shortDescription": {
                                "text": "Identifies potential security misconfigurations or weak practices."
                            },
                            "fullDescription": {
                                "text": "Highlights code that might not be directly malicious but introduces security risks or violates best practices, potentially leading to vulnerabilities."
                            },
                            "helpUri": "https://example.com/help/SEC-WARN-001"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}