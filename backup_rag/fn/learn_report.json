{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "ArbitraryCodeExecution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "This rule identifies patterns that could lead to arbitrary code execution, allowing an attacker to run malicious code on the system."
                            },
                            "helpUri": "https://example.com/rce-001"
                        },
                        {
                            "id": "SEC-WARN-002",
                            "name": "InsecureFileOperations",
                            "shortDescription": {
                                "text": "Detects insecure file system operations."
                            },
                            "fullDescription": {
                                "text": "This rule flags operations that interact with the file system in a potentially insecure manner, such as writing to arbitrary paths or handling sensitive files without proper permissions."
                            },
                            "helpUri": "https://example.com/sec-warn-002"
                        },
                        {
                            "id": "PROMPT-INJ-003",
                            "name": "PromptInjection",
                            "shortDescription": {
                                "text": "Detects potential prompt injection vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "This rule identifies inputs or processing logic that could allow an attacker to manipulate the behavior of an AI agent through crafted prompts."
                            },
                            "helpUri": "https://example.com/prompt-inj-003"
                        },
                        {
                            "id": "INFO-001",
                            "name": "InformationalFinding",
                            "shortDescription": {
                                "text": "Identifies informational findings or benign code patterns."
                            },
                            "fullDescription": {
                                "text": "This rule highlights code segments that are deemed safe or provide general information about the skill's functionality without posing a direct security risk."
                            },
                            "helpUri": "https://example.com/info-001"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}