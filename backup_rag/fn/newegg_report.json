{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "ArbitraryCodeExecution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies code patterns that could allow an attacker to execute arbitrary commands or code on the host system, leading to full system compromise."
                            },
                            "helpUri": "https://example.com/help/RCE-001"
                        },
                        {
                            "id": "CRED-001",
                            "name": "InsecureCredentialHandling",
                            "shortDescription": {
                                "text": "Detects insecure handling or exfiltration of credentials."
                            },
                            "fullDescription": {
                                "text": "Flags code that stores, transmits, or processes sensitive user credentials (e.g., passwords, API keys) in an insecure manner, potentially leading to credential theft."
                            },
                            "helpUri": "https://example.com/help/CRED-001"
                        },
                        {
                            "id": "PI-001",
                            "name": "PromptInjection",
                            "shortDescription": {
                                "text": "Detects prompt injection vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies potential prompt injection attack vectors where untrusted input can manipulate the agent's behavior or access sensitive information."
                            },
                            "helpUri": "https://example.com/help/PI-001"
                        },
                        {
                            "id": "SEC-WARN-001",
                            "name": "ExposedSecrets",
                            "shortDescription": {
                                "text": "Detects hardcoded secrets or exposed sensitive information."
                            },
                            "fullDescription": {
                                "text": "Flags instances where sensitive information, such as API keys, tokens, or configuration secrets, are hardcoded or exposed in publicly accessible files."
                            },
                            "helpUri": "https://example.com/help/SEC-WARN-001"
                        },
                        {
                            "id": "DATA-EXFIL-001",
                            "name": "DataExfiltration",
                            "shortDescription": {
                                "text": "Detects potential data exfiltration attempts."
                            },
                            "fullDescription": {
                                "text": "Identifies code that attempts to send sensitive data to unauthorized external destinations, indicating potential data exfiltration."
                            },
                            "helpUri": "https://example.com/help/DATA-EXFIL-001"
                        },
                        {
                            "id": "SUPPLY-CHAIN-001",
                            "name": "SupplyChainCompromise",
                            "shortDescription": {
                                "text": "Detects indicators of supply chain compromise or malicious dependencies."
                            },
                            "fullDescription": {
                                "text": "Flags suspicious dependencies, typosquatting, or other indicators that the skill might be part of a broader supply chain attack."
                            },
                            "helpUri": "https://example.com/help/SUPPLY-CHAIN-001"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}