{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "RCE-001",
                            "name": "Remote Code Execution",
                            "shortDescription": {
                                "text": "Detects arbitrary code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Identifies code patterns or configurations that allow an attacker to execute arbitrary commands on the host system, potentially leading to full system compromise, data exfiltration, or system modification."
                            },
                            "helpUri": "https://example.com/rce-001-help"
                        }
                    ]
                }
            },
            "results": [
                {
                    "ruleId": "RCE-001",
                    "level": "error",
                    "message": {
                        "text": "A CVSS CRITICAL vulnerability was detected on line 5. The 'spawn' skill declares 'Bash' as an 'allowed-tool', granting arbitrary command execution capabilities. This allows an attacker or compromised agent to execute any shell command, leading to potential data exfiltration, system modification, malware deployment, or complete system compromise (Remote Code Execution)."
                    },
                    "locations": [
                        {
                            "physicalLocation": {
                                "artifactLocation": {
                                    "uri": "spawn-skill/SKILL.md"
                                },
                                "region": {
                                    "startLine": 5,
                                    "endLine": 5,
                                    "snippet": {
                                        "text": "allowed-tools: \"Read Write Bash WebSearch WebFetch AskUserQuestion\""
                                    }
                                }
                            }
                        }
                    ],
                    "properties": {
                        "cvss_severity": "CRITICAL",
                        "threat_category": "RCE"
                    }
                }
            ]
        }
    ]
}