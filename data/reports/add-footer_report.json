{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "MAL-001",
                            "name": "Potential Malware",
                            "shortDescription": {
                                "text": "Identifies behaviors indicative of malware."
                            },
                            "fullDescription": {
                                "text": "Detects patterns associated with malicious software, including persistence, data exfiltration, and command and control."
                            },
                            "helpUri": "https://example.com/malware-rules#MAL-001"
                        },
                        {
                            "id": "EXFIL-001",
                            "name": "Data Exfiltration",
                            "shortDescription": {
                                "text": "Detects attempts to exfiltrate sensitive data."
                            },
                            "fullDescription": {
                                "text": "Flags code that attempts to send sensitive information to external, potentially unauthorized, destinations."
                            },
                            "helpUri": "https://example.com/malware-rules#EXFIL-001"
                        },
                        {
                            "id": "RCE-001",
                            "name": "Remote Code Execution",
                            "shortDescription": {
                                "text": "Identifies potential remote code execution vulnerabilities."
                            },
                            "fullDescription": {
                                "text": "Highlights code constructs that could allow an attacker to execute arbitrary code on the system remotely."
                            },
                            "helpUri": "https://example.com/malware-rules#RCE-001"
                        },
                        {
                            "id": "PERSIST-001",
                            "name": "Persistence Mechanism",
                            "shortDescription": {
                                "text": "Detects mechanisms for maintaining persistence on a system."
                            },
                            "fullDescription": {
                                "text": "Flags code that attempts to establish or modify system persistence, such as registry modifications, scheduled tasks, or service installations."
                            },
                            "helpUri": "https://example.com/malware-rules#PERSIST-001"
                        },
                        {
                            "id": "PHISH-001",
                            "name": "Phishing/Social Engineering",
                            "shortDescription": {
                                "text": "Identifies elements used in phishing or social engineering attacks."
                            },
                            "fullDescription": {
                                "text": "Flags content designed to trick users into revealing credentials or performing actions against their interest, often involving deceptive links or prompts."
                            },
                            "helpUri": "https://example.com/malware-rules#PHISH-001"
                        }
                    ]
                }
            },
            "results": []
        }
    ]
}