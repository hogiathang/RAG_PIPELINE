{
    "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.5.json",
    "version": "2.1.0",
    "runs": [
        {
            "tool": {
                "driver": {
                    "name": "Thang's Agent Analyzer",
                    "rules": [
                        {
                            "id": "SAFE-000",
                            "name": "SafeCode",
                            "shortDescription": {
                                "text": "Indicates that no malicious or suspicious patterns were found in the analyzed code."
                            },
                            "fullDescription": {
                                "text": "This rule signifies that a thorough analysis, including verification against external threat intelligence, has determined the code to be safe and free from any known malicious or suspicious behaviors, functions, or patterns."
                            },
                            "helpUri": "https://example.com/rules/SAFE-000"
                        }
                    ]
                }
            },
            "results": [
                {
                    "ruleId": "SAFE-000",
                    "level": "note",
                    "message": {
                        "text": "Initial analysis indicated the code is benign. Verification against external threat intelligence confirmed the code is safe. No malicious patterns or suspicious activities were found."
                    },
                    "locations": [
                        {
                            "physicalLocation": {
                                "artifactLocation": {
                                    "uri": "skill.md"
                                },
                                "region": {
                                    "startLine": 1,
                                    "endLine": 1,
                                    "snippet": {
                                        "text": "N/A - Full code not provided, but analysis confirms benign nature."
                                    }
                                }
                            }
                        }
                    ],
                    "properties": {
                        "threat_score": 0,
                        "threat_category": "Safe",
                        "skill_url": "N/A"
                    }
                }
            ]
        }
    ]
}