                        {
                            "id": "SEC-CRED-001",
                            "name": "Credential Handling Best Practices",
                            "shortDescription": {
                                "text": "Identifies insecure handling or exposure of sensitive credentials."
                            },
                            "fullDescription": {
                                "text": "This rule flags instances where sensitive credentials, such as API keys or tokens, are handled in a manner that could lead to their exposure (e.g., in shell history, process lists, or insecure storage). While credential handling is often necessary for authenticated tools, best practices must be followed to minimize risk."
                            },
                            "helpUri": "https://example.com/sec-cred-001"
                        },
                        {
                            "id": "SEC-API-001",
                            "name": "Arbitrary API Execution Capability",
                            "shortDescription": {
                                "text": "Flags tools that allow execution of arbitrary API calls, posing a risk if misused."
                            },
                            "fullDescription": {
                                "text": "This rule identifies features that enable users to execute unconstrained or arbitrary API queries/mutations against external services. While this can be an intended and powerful feature for advanced users, it significantly increases the risk of unauthorized data access, modification, or exfiltration if the tool or the user's credentials are compromised."
                            },
                            "helpUri": "https://example.com/sec-api-001"
                        },
                        {
                            "id": "SEC-SCM-001",
                            "name": "Software Supply Chain Risk",
                            "shortDescription": {
                                "text": "Highlights potential software supply chain vulnerabilities from package installations."
                            },
                            "fullDescription": {
                                "text": "This rule points out the inherent risks associated with installing software packages from public repositories (e.g., npm, PyPI). Such installations introduce dependencies on external code, which can be a vector for supply chain attacks, including typosquatting, package compromise, or malicious code injection."
                            },
                            "helpUri": "https://example.com/sec-scm-001"
                        },
                        {
                            "id": "INFO-FSN-001",
                            "name": "Legitimate File System and Network Interaction",
                            "shortDescription": {
                                "text": "Notes legitimate file system and network operations without confirmed malicious intent."
                            },
                            "fullDescription": {
                                "text": "This rule documents standard and expected file system access (reading, writing, deleting files) and network communications (uploads, downloads) that are part of a tool's intended functionality. While these behaviors can be associated with malicious activity, in this context, they are deemed legitimate and do not indicate confirmed malicious intent."
                            },
                            "helpUri": "https://example.com/info-fsn-001"
                        }
                    ]
                }
